# ==============================================================================
# LexiLift Environment Variables Example
# Copy this file to .env.local and fill in the values
# ==============================================================================

# ------------------------------------------------------------------------------
# App / Node
# ------------------------------------------------------------------------------
NODE_ENV="development"

# ------------------------------------------------------------------------------
# Supabase & Database
# ------------------------------------------------------------------------------
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# Your Supabase Anon Key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Your Supabase Service Role Key (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Connection string for Drizzle ORM (use the Transaction pooler URL if possible)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lexilift"

# ------------------------------------------------------------------------------
# AI & Vector Store
# ------------------------------------------------------------------------------
# OpenAI API Key (used for text embeddings and GPT-4o chat)
OPENAI_API_KEY="sk-..."

# Pinecone Vector Database API Key
PINECONE_API_KEY="pcsk_..."

# Pinecone Index Name
PINECONE_INDEX="lexilift"

# Voyage AI API Key (used for Reranking)
VOYAGE_API_KEY="pa-..."

# ------------------------------------------------------------------------------
# Billing (Polar.sh)
# ------------------------------------------------------------------------------
# Polar Access Token
POLAR_ACCESS_TOKEN="polar_..."

# Polar Webhook Secret for /api/webhooks/polar
POLAR_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------------------------
# Email / Marketing (Resend)
# ------------------------------------------------------------------------------
# Resend API Key for waitlist / transactional emails
RESEND_API_KEY="re_..."
